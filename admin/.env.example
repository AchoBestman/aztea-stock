# URL de l'API (inclure /api/v1)
VITE_API_BASE_URL=http://localhost:8080/api/v1

# Port du serveur de dev Vite
VITE_DEV_PORT=5173

# --- Cloudflare R2 (upload logo tenant en dev/preview) ---
# Copier ce fichier vers admin/.env et remplir les valeurs.
# Dashboard Cloudflare : R2 → votre bucket → « Manage R2 API Tokens »
# Ne pas préfixer VITE_ pour les secrets (restent côté serveur Node uniquement).

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# URL publique du bucket (domaine r2.dev ou custom domain)
VITE_R2_PUBLIC_URL=https://your-bucket.r2.dev

# Optionnel : alias serveur (sinon VITE_R2_PUBLIC_URL est utilisé pour construire l'URL du logo)
# R2_PUBLIC_URL=https://your-bucket.r2.dev
