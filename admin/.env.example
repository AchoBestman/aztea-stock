# URL de l'API (inclure /api/v1)
VITE_API_BASE_URL=http://localhost:8080/api/v1

# Port du serveur de dev Vite
VITE_DEV_PORT=5173

# Cloudflare R2 (utilisé par le middleware Vite en dev/preview — ne pas préfixer VITE_ pour les secrets)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
VITE_R2_PUBLIC_URL=https://your-bucket.r2.dev
